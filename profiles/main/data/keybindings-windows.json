[
    // ============================================================
    // 1. SUGERENCIAS E IMPORTACIONES (CTRL+I)
    // ============================================================
    {
        "key": "ctrl+i",
        "command": "editor.action.triggerSuggest",
        "when": "editorTextFocus && !editorReadonly"
    },
    // BLOQUEO: Evitamos que cualquier IA use Ctrl+I
    { "key": "ctrl+i", "command": "-inlineChat.start" },
    { "key": "ctrl+i", "command": "-windsurf.prioritized.command.open" },
    { "key": "ctrl+i", "command": "-geminicodeassist.showinEditor" },
    { "key": "ctrl+i", "command": "-bitoAI.chat.start" },
    { "key": "ctrl+i", "command": "-inlineChat.askInChat" },
    { "key": "ctrl+i", "command": "-workbench.action.chat.startVoiceChat" },

    // ============================================================
    // 2. FORMATEO (CTRL+SHIFT+I)
    // ============================================================
    {
        "key": "ctrl+shift+i",
        "command": "editor.action.formatDocument",
        "when": "editorTextFocus && !editorReadonly"
    },
    // Desactivamos el atajo por defecto de VS Code para no tener duplicados
    { "key": "shift+alt+f", "command": "-editor.action.formatDocument" },

    // ============================================================
    // 3. WINDSURF (CTRL+SHIFT+C)
    // ============================================================
    {
        "key": "ctrl+shift+c",
        "command": "windsurf.triggerCascade",
        "when": "true" 
    },
    { "key": "ctrl+shift+c", "command": "-workbench.action.terminal.openNativeConsole" },
    { "key": "ctrl+shift+c", "command": "-workbench.action.terminal.copySelection" },

    // ============================================================
    // 4. OTROS (ALINEACIÓN Y COMENTARIOS)
    // ============================================================
    {
        "key": "alt+a",
        "command": "wwm.aligncode",
        "when": "editorTextFocus && !editorReadonly"
    },
    { "key": "alt+a", "command": "-continue.applyCodeFromChat" },
    {
        "key": "ctrl+shift+7",
        "command": "editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+k ctrl+c",
        "command": "editor.action.addCommentLine",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+k ctrl+u",
        "command": "editor.action.removeCommentLine",
        "when": "editorTextFocus && !editorReadonly"
    }
]