[
    // --- 1. ALINEACIÓN (BETTER ALIGN) ---
    {
        "key": "alt+a",
        "command": "wwm.aligncode",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "alt+a",
        "command": "-continue.applyCodeFromChat" 
    },

    // --- 2. SUGERENCIAS Y BLOQUEO DE IA (CTRL+I) ---
    {
        "key": "ctrl+i",
        "command": "editor.action.triggerSuggest",
        "when": "editorTextFocus && !editorReadonly"
    },
    // Quitamos el permiso a todas las IAs de usar Ctrl+I
    { "key": "ctrl+i", "command": "-inlineChat.start" },
    { "key": "ctrl+i", "command": "-workbench.action.terminal.chat.start" },
    { "key": "ctrl+i", "command": "-inlineChat.startWithCurrentLine" },
    { "key": "ctrl+i", "command": "-bitoAI.chat.start" },
    { "key": "ctrl+i", "command": "-bitoAI.openChat" },

    // --- 3. FORMATEO DE DOCUMENTO (CTRL+SHIFT+I) ---
    {
        "key": "ctrl+shift+i",
        "command": "editor.action.formatDocument",
        "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
    },
    // Desactivamos el Shift+Alt+F para que no haga conflicto
    {
        "key": "shift+alt+f",
        "command": "-editor.action.formatDocument"
    },

    // --- 4. COMENTARIOS (ESTILO LIMPIO) ---
    {
        "key": "ctrl+shift+7",
        "command": "editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+k ctrl+c",
        "command": "editor.action.addCommentLine",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+k ctrl+u",
        "command": "editor.action.removeCommentLine",
        "when": "editorTextFocus && !editorReadonly"
    },

    // --- 5. CHAT DE IA (RE-UBICADO PARA QUE NO MOLESTE) ---
    {
        "key": "ctrl+shift+q",
        "command": "workbench.action.chat.openagent",
        "when": "config.chat.agent.enabled && !chatSetupDisabled && !chatSetupHidden"
    },
    {
        "key": "ctrl+shift+i",
        "command": "windsurf.cascadePanel.focus"
    }
]